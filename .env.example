# ─────────────────────────────────────────────────
#  Lumière Store Builder Agent — Environment Keys
# ─────────────────────────────────────────────────

# REQUIRED — Free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# REQUIRED — Free at tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# OPTIONAL — For live Shopify deployment
# Free dev store at partners.shopify.com
# Admin → Settings → Apps → Develop apps → Create app
SHOPIFY_STORE_URL=leumiere-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here
